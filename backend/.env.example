# -----------------------------------------------------------------------------
# MONTO AI - Backend Configuration Example
# -----------------------------------------------------------------------------
# กรุณาคัดลอกไฟล์นี้เป็น .env แล้วเติมข้อมูลให้ครบถ้วนก่อนเริ่มใช้งาน
# -----------------------------------------------------------------------------

# [REQUIRED] Google Gemini API Key
# รับได้ฟรีที่: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# [REQUIRED] Database Connection String
# รูปแบบ: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# หากรันผ่าน Docker Compose ให้ใช้ค่าด้านล่างนี้ได้เลย:
DATABASE_URL="mysql://user:user_password@db:3306/ai_agent_db"

# [REQUIRED] JWT Secret Key
# ใช้สำหรับเข้ารหัสความปลอดภัยของระบบ Login (ควรเป็นข้อความยาวๆ ที่เดายาก)
JWT_SECRET=monto_ai_super_secret_key_change_me

# [OPTIONAL] Server Port
# พอร์ตที่ Backend จะรัน (ค่าเริ่มต้นคือ 5000)
PORT=5000

# [OPTIONAL] Environment Mode
# กำหนดเป็น 'production' เมื่อใช้งานจริง
NODE_ENV=development
